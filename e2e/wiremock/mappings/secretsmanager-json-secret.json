{
  "request": {
    "method": "POST",
    "urlPath": "/",
    "headers": {
      "X-Amz-Target": {
        "equalTo": "secretsmanager.GetSecretValue"
      }
    },
    "bodyPatterns": [
      {
        "contains": "\"SecretId\":\"MyJsonSecret\""
      }
    ]
  },
  "response": {
    "status": 200,
    "headers": {
      "Content-Type": "application/x-amz-json-1.1"
    },
    "jsonBody": {
      "ARN": "arn:aws:secretsmanager:ap-southeast-2:000000000000:secret:MyJsonSecret",
      "Name": "MyJsonSecret",
      "SecretString": "{ \"srmName\": \"test\", \"srmTest\": \"objectName\"}",
      "VersionId": "00000000-0000-0000-0000-000000000002",
      "VersionStages": [
        "AWSCURRENT"
      ]
    }
  }
}
