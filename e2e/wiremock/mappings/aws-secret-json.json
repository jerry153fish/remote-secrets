{
  "priority": 1,
  "request": {
    "method": "POST",
    "urlPath": "/",
    "headers": {
      "x-amz-target": {
        "equalTo": "secretsmanager.GetSecretValue"
      }
    },
    "bodyPatterns": [
      {
        "matchesJsonPath": "$[?(@.SecretId == 'MyJsonSecret')]"
      }
    ]
  },
  "response": {
    "status": 200,
    "headers": {
      "Content-Type": "application/x-amz-json-1.1"
    },
    "jsonBody": {
      "ARN": "arn:aws:secretsmanager:ap-southeast-2:000000000000:secret:MyJsonSecret",
      "CreatedDate": 0,
      "Name": "MyJsonSecret",
      "SecretString": "{ \"srmName\": \"test\", \"srmTest\": \"objectName\"}",
      "VersionId": "1",
      "VersionStages": [
        "AWSCURRENT"
      ]
    }
  }
}
