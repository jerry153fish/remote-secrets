{
  "request": {
    "method": "POST",
    "urlPath": "/",
    "headers": {
      "X-Amz-Target": {
        "equalTo": "AmazonSSM.GetParameter"
      }
    },
    "bodyPatterns": [
      {
        "contains": "\"Name\":\"MyStringParameter\""
      }
    ]
  },
  "response": {
    "status": 200,
    "headers": {
      "Content-Type": "application/x-amz-json-1.1"
    },
    "jsonBody": {
      "Parameter": {
        "ARN": "arn:aws:ssm:ap-southeast-2:000000000000:parameter/MyStringParameter",
        "DataType": "text",
        "Name": "MyStringParameter",
        "Type": "String",
        "Value": "Vici",
        "Version": 1
      }
    }
  }
}
